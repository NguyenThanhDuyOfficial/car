// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  HOST
  USER
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  avatarUrl String?
  isActive  Boolean @default(true)

  role         Role    @default(USER)
  refreshToken String?

  cars     Car[]
  orders   Order[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reviews   Review[]

  @@index([email])
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  GASOLINE
  DIESEL
  ELECTRIC
}

enum CarStatus {
  AVAILABLE
  BOOKED
}

model Car {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  title        String
  description  String?
  licensePlate String?
  brand        String?
  model        String?
  seatCount    Int
  transmission Transmission
  fuelType     FuelType

  carFeatures CarFeature[]
  images      Image[]

  status         CarStatus @default(AVAILABLE)
  pickupLocation String
  dailyPrice     Decimal   @db.Decimal(10, 2)

  orders  Order[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([pickupLocation])
  @@index([dailyPrice])
}

model Image {
  id  String @id @default(cuid())
  url String

  car   Car?    @relation(fields: [carId], references: [id])
  carId String?
}

model Feature {
  id    String @id @default(cuid())
  title String @unique

  carFeatures CarFeature[]
}

model CarFeature {
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([carId, featureId])
  @@index([carId])
  @@index([featureId])
}

model Review {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  carId  String
  car    Car    @relation(fields: [carId], references: [id])

  title     String
  rating    Int      @default(0)
  comment   String?
  createdAt DateTime @default(now())

  @@index([carId])
  @@index([rating])
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  REFUNDED
  COMPLETED
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  carId  String
  car    Car    @relation(fields: [carId], references: [id])

  pickupTime        DateTime
  dropoffTime       DateTime
  actualPickupTime  DateTime?
  actualDropoffTime DateTime?

  dailyPrice      Decimal @db.Decimal(15, 2)
  carInsurance    Decimal @db.Decimal(15, 2)
  renterInsurance Decimal @db.Decimal(15, 2)
  overLimitFee    Decimal @db.Decimal(15, 2)
  overTimeFee     Decimal @db.Decimal(15, 2)
  cleaningFee     Decimal @db.Decimal(15, 2)
  deodorizingFee  Decimal @db.Decimal(15, 2)
  totalAmount     Decimal @db.Decimal(15, 2)

  status OrderStatus @default(PENDING)

  driverNotes        String?
  customerNotes      String?
  cancellationReason String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([carId])
  @@index([status])
  @@map("orders")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  paymentMethod String
  paymentType   String

  amount         Decimal       @db.Decimal(15, 2)
  transationCode String
  status         PaymentStatus @default(PENDING)
  paymentDate    DateTime

  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([paymentDate])
}
